# Copiar a .env (no subir .env a git)

# Servidor: ej. 192.168.1.128\comercial  o  tcp:mi-servidor.database.windows.net,1433
DC_SQLSERVER=192.168.1.128\\comercial

# Base de empresa Comercial (ej. adCONCRETOS_NUEVA)
DC_DATABASE=adCONCRETOS_NUEVA

# Usuario SQL con permisos mínimos (evitar sa)
DC_SQLUSER=dcconc_readtrace
DC_SQLPASSWORD=cambiar_por_secreto

# Opcional: TrustServerCertificate=yes en redes internas con certificado autofirmado
DC_ODBC_EXTRA=TrustServerCertificate=yes
